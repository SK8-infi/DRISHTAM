# ── DRISHTAM Environment Configuration ───────────────────────
# Copy to .env and fill in your values.

# Environment: "development" or "production"
DRISHTAM_ENV=development

# MapMyIndia API key (get from https://apis.mappls.com/)
MMI_KEY=your_mapmyindia_key_here

# API URL (for local dev, dashboard connects directly)
NEXT_PUBLIC_API_URL=http://localhost:8000

# MapMyIndia key for frontend
NEXT_PUBLIC_MMI_KEY=your_mapmyindia_key_here

# ── Security Settings ────────────────────────────────────────

# CORS allowed origins (comma-separated)
DRISHTAM_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted hosts (comma-separated, use * for development)
DRISHTAM_ALLOWED_HOSTS=*

# Rate limit: max requests per 60-second window per IP
DRISHTAM_RATE_LIMIT=300

# ── Data Settings ────────────────────────────────────────────

# Local data override (skip GCS download, use local files)
# DRISHTAM_DATA_DIR=/path/to/project/root

# GCS cache directory (default: ~/.cache/drishtam)
# DRISHTAM_CACHE_DIR=/app/cache
